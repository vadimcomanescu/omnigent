<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Signing entitlements for the packaged macOS app (electron-builder
  `mac.entitlements`; helpers use entitlements.mac.inherit.plist).

  (This lives in signing/, not build/, because the repo-root .gitignore
  ignores all build/ directories.)
-->
<plist version="1.0">
  <dict>
    <!-- Electron under the hardened runtime needs JIT for V8. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Voice dictation (mic level meter / Web Speech). -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
    <!-- WebAuthn Touch ID platform authenticator: the keychain access group
         that stores the Secure Enclave passkeys (app.configureWebAuthn).

         keychain-access-groups is a RESTRICTED entitlement — three pieces
         must stay in lockstep or AMFI SIGKILLs the app at launch ("Launchd
         job spawn failed", POSIX error 163):
           1. this entitlement,
           2. WEBAUTHN_KEYCHAIN_ACCESS_GROUP in src/main.js (same string),
           3. the embedded Developer ID provisioning profile
              (signing/omnigent.provisionprofile, wired via
              `provisioningProfile` in package.json's `build.mac`), whose
              allowlist `8RMX4WU6F8.*` authorizes the group. The signing
              identity must be the same team (package.json pins
              "Databricks, Inc. (8RMX4WU6F8)"). -->
    <key>keychain-access-groups</key>
    <array>
      <string>8RMX4WU6F8.ai.omnigent.desktop</string>
    </array>
  </dict>
</plist>
